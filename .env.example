# Optional: residential proxy (recommended for production)
PROXY_URL=

# Optional: only needed if public scraping fails without login
INSTAGRAM_SESSION_ID=

# ── Production scaling (optional) ─────────────────────────────────────────
# Multiple residential proxies (comma-separated):
# PROXY_URLS=http://user:pass@proxy1:port,http://user:pass@proxy2:port
#
# Multiple sessions — rarely needed; only if you hit login walls at scale:
# INSTAGRAM_SESSION_IDS=session1,session2
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=5.0
MAX_RETRIES=3

# Instagram app ID for mobile API calls (update if requests start failing)
INSTAGRAM_APP_ID=936619743392459

# ── Free local AI (no API keys needed) ────────────────────────────────────
# Audio transcription — local Whisper (install ffmpeg: brew install ffmpeg)
WHISPER_MODEL=base

# On-screen text OCR — EasyOCR runs automatically (no config needed)
#
# Optional: better OCR via Ollama vision (free, runs on your Mac)
#   brew install ollama
#   ollama pull moondream
# OLLAMA_URL=http://localhost:11434
# OLLAMA_VISION_MODEL=moondream
